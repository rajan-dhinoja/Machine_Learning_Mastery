            "\n",
            "\n",
            "New Data with replaced missing values: \n",
            "    Country   Age    Salary Purchased\n",
            "0   France 44.00 72,000.00        No\n",
            "1    Spain 27.00 48,000.00       Yes\n",
            "2  Germany 30.00 54,000.00        No\n",
            "3    Spain 37.33 61,000.00        No\n",
            "4  Germany 40.00 62,500.00       Yes\n",
            "5   France 35.00 63,700.00       Yes\n",
            "6   France 36.00 52,000.00        No\n",
            "7   France 37.33 79,000.00       Yes\n",
            "8  Germany 50.00 83,000.00        No\n",
            "9   France 37.00 58,500.00       Yes\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "### Step-3.3: Checking any Synonyms or Aliases and Handling them:-"
      ],
      "metadata": {
        "id": "7R1bgdUOSKLX"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "for col in dataset.columns:\n",
        "  # Get value counts and convert to DataFrame with column name\n",
        "  # .reset_index(name='Counts: '): This converts the Series into a DataFrame and names the count column as 'Counts: '.\n",
        "  value_counts_dataset = dataset[col].value_counts().rename_axis('Unique Values: ').reset_index(name='Counts: ')\n",
        "\n",
        "  # Transpose and print with formatting\n",
        "  print(f\"Column: \\t'{col}'\")\n",
        "  # .to_string(header=False): This converts the transposed DataFrame to a string for printing and removes the header row.\n",
        "  print(value_counts_dataset.T.to_string(header=False), \"\\n\")\n"
      ],
      "metadata": {
        "id": "Z2k59LVqTC8u",
        "outputId": "256d4754-7123-4c26-9865-b2717b5b16e4",
        "colab": {
          "base_uri": "https://localhost:8080/"
        }
      },
      "execution_count": 9,
      "outputs": [
        {
